# Azure AD app registration (required for UW sign-in + SharePoint access)
# See docs/AZURE_SETUP.md
VITE_AZURE_CLIENT_ID=your-application-client-id

# UW tenant ID (optional). Use "organizations" for any work/school account.
VITE_AZURE_TENANT_ID=organizations

# SharePoint sharing link to the Excel tracker
VITE_SHAREPOINT_TRACKER_URL=https://uwnetid-my.sharepoint.com/:x:/g/personal/msti_uw_edu/ETpJ7eJ5fX5MhYk6FkmtnZwBw1IwHy7RyB_GEPDntEYpAw?e=7SNNoE

# Auto-refresh interval in ms while signed in (default 120000 = 2 minutes)
VITE_TRACKER_REFRESH_MS=120000
